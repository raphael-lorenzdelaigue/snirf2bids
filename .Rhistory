install_python_user <- function() {
installer <- "install/python-3.9.13-amd64.exe"
install_dir <- normalizePath("install/Python39User", mustWork = FALSE)
expected_python_path <- file.path(install_dir, "python.exe")
# 1. Check if installer is present
if (!file.exists(installer)) {
stop("❌ Python installer not found at: ", installer)
}
# 2. Silent install (user-level)
cat("⚙️ Attempting silent user-level install of Python...\n")
status <- system2(installer, args = c(
"/quiet",
"InstallAllUsers=0",                  # User install
paste0("TargetDir=", shQuote(install_dir)),  # User-specified path
"PrependPath=0",                      # Optional: avoid touching PATH
"Include_test=0",
"Include_launcher=0"
))
# 3. Check result
if (status != 0) {
stop("❌ Python installation failed with status code: ", status)
}
# 4. Verify Python executable
if (!file.exists(expected_python_path)) {
stop("❌ Python installed, but executable not found at: ", expected_python_path)
}
cat("✅ Python installed successfully at: ", expected_python_path, "\n")
return(expected_python_path)
}
