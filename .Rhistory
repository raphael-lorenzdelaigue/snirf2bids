print_hdf5_structure <- function(group, prefix = "") {
for (name in group$keys()) {
item <- group[[name]]
path <- paste0(prefix, "/", name)
if (reticulate::py_has_attr(item, "keys")) {
cat("📁 Group:", path, "\n")
print_hdf5_structure(item, path)
} else {
# dataset
tryCatch({
value <- item$asstr()[[1]]
}, error = function(e) {
value <- tryCatch(as.character(item[()]), error = function(e) "<binary>")
print_hdf5_structure <- function(group, prefix = "") {
for (name in group$keys()) {
item <- group[[name]]
path <- paste0(prefix, "/", name)
if (reticulate::py_has_attr(item, "keys")) {
cat("📁 Group:", path, "\n")
print_hdf5_structure(item, path)
} else {
# Dataset: try to read as string, fallback to numeric/scalar
value <- tryCatch({
item$asstr()$tolist()  # works for ASCII/UTF-8 datasets
}, error = function(e) {
tryCatch({
item$`__getitem__`(reticulate::tuple())  # equivalent to item[()]
}, error = function(e) "<unreadable>")
})
# Format value if it's a vector
if (is.list(value) || is.vector(value)) {
value <- paste(value, collapse = ", ")
}
cat("📄 Dataset:", path, "=>", value, "\n")
}
}
}
